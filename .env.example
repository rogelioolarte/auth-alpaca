# Database Configuration
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres-db:5432/auth-alpaca
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_db_password

SPRING_DATASOURCE_MAXIMUM_POOL_SIZE=50
SPRING_DATASOURCE_MINIMUM_IDLE=10

# JWT Configuration
JWT_ISSUER=auth-alpaca.com

# Access Token Duration - 5 Min
JWT_ACCESS_TOKEN_EXPIRATION=300000
# Access Token Duration - 12 Hours
JWT_REFRESH_TOKEN_EXPIRATION=43200000

# JWT RSA Key File Path
JWT_ACCESS_PRIVATE_KEY_PATH=file:/keys/access_private.pem
JWT_ACCESS_PUBLIC_KEY_PATH=file:/keys/access_public.pem

JWT_REFRESH_PRIVATE_KEY_PATH=file:/keys/refresh_private.pem
JWT_REFRESH_PUBLIC_KEY_PATH=file:/keys/refresh_public.pem

# OAuth2 Configuration
APP_FRONTEND_URI=http://localhost:80
GOOGLE_CLIENT_ID=client_id
GOOGLE_CLIENT_SECRET=client_secret

# Security Settings
MAX_SESSIONS_PER_USER=5
INFINITY_LOGIN=false

# Password Encoder
BCRYPT_COST_FACTOR=12

# App Settings
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=123456789

RATELIMIT_MAX_RPM=500

# Frontend
NG_API_URL=http://localhost:8080
NG_UI_URL=http://localhost:80
NG_INFINITY_LOGIN=false